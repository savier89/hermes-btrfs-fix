+
+# Retry configuration for WAL setup.  On filesystems with Copy-on-Write
+# semantics (BTRFS, ZFS) or under high concurrency, transient locking
+# errors may occur during WAL initialization.  Retry with backoff gives
+# SQLite time to settle before falling back to DELETE mode.
+#
+# Users can override via environment variables:
+#   HERMES_SQLITE_BUSY_TIMEOUT=30000  # milliseconds (default: 30000)
+#   HERMES_SQLITE_WAL_RETRIES=3       # max attempts (default: 3)
+#   HERMES_SQLITE_WAL_RETRY_DELAY=1.0 # seconds between attempts (default: 1.0)
+import os as _os
+_STATE_DB_BUSY_TIMEOUT_MS = int(_os.environ.get("HERMES_SQLITE_BUSY_TIMEOUT", "30000"))
+_WAL_SETUP_MAX_ATTEMPTS = int(_os.environ.get("HERMES_SQLITE_WAL_RETRIES", "3"))
+_WAL_SETUP_RETRY_DELAY_S = float(_os.environ.get("HERMES_SQLITE_WAL_RETRY_DELAY", "1.0"))
+del _os
+
