+    # On BTRFS, use increased busy_timeout + retry to handle COW conflicts
+    if db_path and _is_on_btrfs(db_path):
+        last_exc = None
+        for attempt in range(_BTRFS_WAL_RETRIES):
+            try:
+                conn.execute("PRAGMA journal_mode=WAL")
