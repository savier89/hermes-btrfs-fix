+def _safe_getcwd() -> str:
+    """Return the current working directory, falling back to home on error.
+
+    ``os.getcwd()`` raises ``FileNotFoundError`` if the process's CWD was
+    deleted (e.g. a temp directory cleaned up while the gateway was still
+    running).  This helper avoids crashing the cleanup thread.
+    """
+    try:
+        return os.getcwd()
+    except FileNotFoundError:
+        return str(Path.home())
