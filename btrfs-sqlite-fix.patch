+# Transient markers that may clear on retry (e.g., BTRFS COW races,
+# concurrent WAL checkpoint, short-lived busy states).  Distinct from
+# _WAL_INCOMPAT_MARKERS which indicate permanent filesystem incompatibility.
+_WAL_TRANSIENT_MARKERS = (
