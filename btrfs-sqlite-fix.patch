+def _is_on_btrfs(path: str) -> bool:
+    """Check if *path* resides on a BTRFS filesystem.
+
+    BTRFS Copy-on-Write semantics conflict with SQLite WAL mode —
+    concurrent readers/writers can trigger ``disk I/O error`` during
+    normal writes (not just WAL setup).  Force DELETE journal mode
+    on BTRFS to avoid silent corruption.
+    """
+    import pathlib
+
+    resolved = str(pathlib.Path(path).resolve())
+    try:
+        with open("/proc/self/mountinfo") as fh:
+            for line in fh:
+                # Format: ID PARENT_ID MAJ:MIN ROOT MOUNTPT OPTIONS - FSTYPE DEV SUPER_OPS
+                # The '-' separator after OPTIONS reliably precedes FSTYPE.
+                try:
+                    dash_idx = line.index("-")
+                except ValueError:
+                    continue
+                before = line[:dash_idx].split()
+                after = line[dash_idx + 1:].split()
+                if len(before) < 5 or len(after) < 1:
+                    continue
+                mount_point = before[4]
+                fstype = after[0] if after else ""
+                if resolved.startswith(mount_point + "/") or resolved == mount_point:
+                    return fstype.lower() == "btrfs"
+    except OSError:
+        pass
+    return False
+
