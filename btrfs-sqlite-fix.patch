+# See: https://wiki.tnonline.net/w/Blog/SQLite_Performance_on_Btrfs
+# Users can override via HERMES_SQLITE_BUSY_TIMEOUT environment variable.
+_BTRFS_BUSY_TIMEOUT_MS = int(__import__("os").environ.get("HERMES_SQLITE_BUSY_TIMEOUT", "5000"))
