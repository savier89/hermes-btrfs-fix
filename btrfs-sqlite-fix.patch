+    # Try WAL mode with increased busy_timeout for better concurrency
+    import time
+    last_exc = None
+    for attempt in range(3):
+        try:
+            conn.execute("PRAGMA journal_mode=WAL")
+            conn.execute("PRAGMA busy_timeout=30000")  # 30 seconds
